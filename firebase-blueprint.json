{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile for donors and recipients",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["donor", "recipient"] },
        "bloodGroup": { "type": "string", "enum": ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "lastDonationDate": { "type": "string", "format": "date-time" },
        "isAvailable": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "role", "bloodGroup"]
    },
    "BloodRequest": {
      "title": "Blood Request",
      "description": "Emergency blood requests created by recipients",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "requesterId": { "type": "string" },
        "bloodGroup": { "type": "string", "enum": ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"] },
        "units": { "type": "number" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "hospitalName": { "type": "string" },
        "urgency": { "type": "string", "enum": ["low", "medium", "high", "emergency"] },
        "status": { "type": "string", "enum": ["open", "fulfilled", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "contactInfo": { "type": "string" }
      },
      "required": ["requesterId", "bloodGroup", "units", "urgency", "status"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Messages between donors and recipients",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["sent", "read"] }
      },
      "required": ["senderId", "text", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notifications for users",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["match", "chat", "system"] },
        "isRead": { "type": "boolean" },
        "requestId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "type", "isRead", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection"
    },
    "/requests/{requestId}": {
      "schema": "BloodRequest",
      "description": "Public blood requests"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a specific chat room"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User-specific notifications"
    }
  }
}
